{
  "manifest_version": 3,
  "name": "Gemini Quad Splitter",
  "version": "1.1",
  "permissions": ["tabs", "storage"],
  "host_permissions": ["https://gemini.google.com/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["content.js"]
    }
  ]
}